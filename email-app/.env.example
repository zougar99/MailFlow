# Port d’écoute (défaut 3001 si absent)
PORT=3001

# Chiffrement des sessions OAuth (obligatoire pour Gmail / Outlook) — min. 16 caractères aléatoires.
# Recommandé : email-app/.env.local (git ignoré). Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_OAUTH_SECRET=change_moi_minimum_16_caracteres_aleatoires

# Gmail : Google Cloud Console → API & Services → Identifiants → OAuth 2.0
# Activer l’API Gmail. URI de redirection autorisée = GOOGLE_REDIRECT_URI (ex. ci-dessous).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Si vide : {origine}/api/email/gmail/callback (ex. port 4000 si tu lances sur 4000)
GOOGLE_REDIRECT_URI=http://localhost:3001/api/email/gmail/callback

# Microsoft : Azure Portal → Inscriptions d’applications → secret client + ID
# Redirect URI type Web : MICROSOFT_REDIRECT_URI
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/email/microsoft/callback

# Module IA (identique à web/)
# WORKFLOW_AI_MODULE=env
# AI_BASE_URL=http://127.0.0.1:11434/v1
# AI_API_KEY=ollama
# AI_MODEL=qwen3.5-27b
